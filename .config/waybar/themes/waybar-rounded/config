{ 
  "layer": "top",
  "width": 600,
  "margin-top": 4,
  "margin-bottom": 8,
  "output": ["DP-1", "DP-2"],

  "modules-left": ["hyprland/workspaces", "custom/dotfiles", "custom/updates"],
  "modules-center": ["clock"],
  "modules-right": ["network", "pulseaudio", "custom/powermenu"],


  "network": {
    "format-wifi": "",
    "format-ethernet": "{ifname} 󰈀",
    "tooltip-format": "Launch Impala",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "⚠",
    "on-click": "kitty --class=kittyfloat impala"
  },

  "clock": {
    "format": "{:%I:%M}",
    "tooltip": false
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": " {volume}%",
    "format-muted": "",
    "format-icons": {
      "headphone": "",
      "headset": "",
      "default": ["󰖀", "󰕾"]
    },
    "scroll-step": 1,
    "on-click": "kitty --class=kittyfloat wiremix"
  },

  // uses the waybar-module-pacman-git aur package
"custom/updates": {
    "format": "󰇚 {}",
    "return-type": "json",
    "format-icons": {
        "has-updates": "󰇚 ",
        "updated": " "
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300",
  },

  // check status of dotfile's (if they need pushed or not)
  "custom/dotfiles": {
    "format": "{}",
    "interval": 10,
    "exec": "~/.config/waybar/scripts/dotfile_status.sh 2> /dev/null",
    "return-type": "json",
  },

  // powermenu through rofi
  "custom/powermenu": {
    "format": "󰐥",
    "on-click": "rofi -show power-menu -modi power-menu:~/.local/bin/powermenu",
    "tooltip-format": "Launch Rofi Powermenu"
  }
}