{
  "layer": "top",
  "width": 1000,
  "margin-bottom": 8,
  "output": ["DP-1", "DP-2"],

  "modules-left": ["custom/powermenu", "custom/separator", "clock"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["pulseaudio","custom/separator", "network"],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "",
      "4": "",
      "5": "",
      "6": ""
    }
  },

  "network": {
    "format-wifi": " {essid}",
    "format-ethernet": "{ifname} 󰈀",
    "tooltip-format": "{ipaddr}/{cidr} via {gwaddr} ",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "Disconnected ⚠",
    "on-click": "kitty --class=kittyfloat impala"
  },

  "clock": {
    "format": "{:%I:%M %p - %b %d}"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": " {volume}%",
    "format-muted": "",
    "format-icons": {
      "headphone": "",
      "headset": "",
      "default": ["󰖀", "󰕾"]
    },
    "scroll-step": 1,
    "on-click": "kitty --class=kittyfloat wiremix"
  },

  "custom/powermenu": {
    "format": " ",
    "on-click": "rofi -show power-menu -modi power-menu:~/.local/bin/powermenu"
  },

  "custom/separator": {
    "format": "|",
    "interval": "once",
    "tooltip": false
  }
}