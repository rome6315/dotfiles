{
  "layer": "top",
  "width": 1000,
  "margin-bottom": 8,
  "output": ["DP-1", "DP-2"],

  "modules-left": ["clock", "custom/updates"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": ["pulseaudio", "network"],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "",
      "4": "",
      "5": "",
      "6": ""
    }
  },

  "network": {
    "format-wifi": "",
    "format-ethernet": "{ifname} 󰈀",
    "tooltip-format": "{ipaddr}/{cidr} via {gwaddr} ",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "⚠",
    "on-click": "kitty --class=kittyfloat impala"
  },

  "clock": {
    "format": "{:%I:%M}",
    "tooltip-format": "Click for Power Menu",
    "on-click": "rofi -show power-menu -modi power-menu:~/.local/bin/powermenu"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-bluetooth": " {volume}%",
    "format-muted": "",
    "format-icons": {
      "headphone": "",
      "headset": "",
      "default": ["󰖀", "󰕾"]
    },
    "scroll-step": 1,
    "on-click": "kitty --class=kittyfloat wiremix"
  },

  // uses the waybar-module-pacman-git aur package
"custom/updates": {
    "format": "󰇚 {}",
    "return-type": "json",
    "format-icons": {
        "has-updates": "󰇚 ",
        "updated": " "
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300",
  }
}